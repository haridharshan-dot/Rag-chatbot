# =========================
# Server Runtime
# =========================

# NODE_ENV
# What it is used for: Switches runtime mode (development or production).
# Where to get it: Set manually. Use "production" on hosted deployments.
NODE_ENV=development

# PORT
# What it is used for: Port where the Express API server listens.
# Where to get it: Set manually. Hosting providers may override this automatically.
PORT=5001

# CLIENT_URL
# What it is used for: Allowed frontend origin for CORS and Socket.IO.
# Where to get it: Your frontend app URL.
# Example hosted value: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# MONGO_URI
# What it is used for: MongoDB connection string for chat sessions/history.
# Where to get it:
# - MongoDB Atlas: https://www.mongodb.com/cloud/atlas/register
# - Atlas connection string docs: https://www.mongodb.com/docs/atlas/connect-to-cluster/
# - Render managed MongoDB: https://render.com/docs/databases
MONGO_URI=mongodb://localhost:27017/college_rag_chatbot

# JWT_SECRET
# What it is used for: Signs and verifies agent authentication tokens.
# Where to get it: Generate a long random secret.
# Generator option: https://www.grc.com/passwords.htm
JWT_SECRET=replace_me_with_strong_secret

# AGENT_USERNAME
# What it is used for: Demo/support agent login username for /agent console.
# Where to get it: Set manually.
AGENT_USERNAME=agent

# AGENT_EMAIL
# What it is used for: Default email credential for local agent login.
# Where to get it: Set manually to your support account email.
AGENT_EMAIL=agent@sona.com

# AGENT_PASSWORD
# What it is used for: Demo/support agent login password for /agent console.
# Where to get it: Set manually (use a strong value in production).
AGENT_PASSWORD=agent123

# AGENT_JWT_EXPIRY
# What it is used for: Expiration period for agent JWT tokens.
# Where to get it: Set manually using ms-style values (for example 12h, 1d).
AGENT_JWT_EXPIRY=12h

# MICROSOFT_AUTH_ENABLED
# What it is used for: Enables agent Microsoft SSO login endpoint.
# Where to get it: Set manually to true to enable.
MICROSOFT_AUTH_ENABLED=false

# MICROSOFT_ALLOWED_DOMAINS
# What it is used for: Comma-separated email domains allowed to sign in as support agents.
# Example: sonatech.ac.in,sona.edu
MICROSOFT_ALLOWED_DOMAINS=

# MICROSOFT_ALLOWED_EMAILS
# What it is used for: Optional comma-separated allow-list of specific agent emails.
MICROSOFT_ALLOWED_EMAILS=

# RATE_LIMIT_WINDOW_MS
# What it is used for: Request throttling window in milliseconds.
# Where to get it: Set manually based on expected traffic.
RATE_LIMIT_WINDOW_MS=60000

# RATE_LIMIT_MAX
# What it is used for: Max requests allowed per IP per rate-limit window.
# Where to get it: Set manually based on expected traffic.
RATE_LIMIT_MAX=100


# =========================
# LLM and RAG Settings
# =========================

# GOOGLE_API_KEY
# What it is used for: Calls Gemini via LangChain to generate grounded answers.
# Where to get it:
# - Google AI Studio: https://aistudio.google.com/app/apikey
# - API docs: https://ai.google.dev/docs
GOOGLE_API_KEY=

# GEMINI_API_KEY
# What it is used for: Alias of GOOGLE_API_KEY (supported as fallback).
GEMINI_API_KEY=

# GEMINI_MODEL
# What it is used for: Gemini model name used for answer generation.
# Where to get it:
# - Model list/docs: https://ai.google.dev/models
GEMINI_MODEL=gemini-2.5-flash-lite

# GEMINI_TIMEOUT_MS
# What it is used for: Max wait for Gemini response before fast fallback to retrieval-only answer.
GEMINI_TIMEOUT_MS=9000

# ANTHROPIC_API_KEY
# What it is used for: Optional fallback model provider key (Claude).
# Where to get it:
# - Anthropic console: https://console.anthropic.com/
# - Key setup docs: https://docs.anthropic.com/en/api/getting-started
ANTHROPIC_API_KEY=

# CLAUDE_MODEL
# What it is used for: Optional fallback Claude model name used when GOOGLE_API_KEY is not set.
# Where to get it:
# - Model list/docs: https://docs.anthropic.com/en/docs/about-claude/models
CLAUDE_MODEL=claude-sonnet-4-20250514

# OPENAI_API_KEY
# What it is used for: Reserved for OpenAI-based embeddings/model flows (optional).
# Where to get it:
# - OpenAI API keys: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OPENAI_EMBEDDING_MODEL
# What it is used for: Reserved model name if you switch to OpenAI embeddings.
# Where to get it:
# - OpenAI embeddings docs: https://platform.openai.com/docs/guides/embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# VECTOR_DB_PROVIDER
# What it is used for: Chooses vector backend.
# Values:
# - local: in-memory LangChain store (simple testing)
# - pinecone: managed vector DB (recommended production)
VECTOR_DB_PROVIDER=local

# PINECONE_API_KEY
# What it is used for: Auth to Pinecone when VECTOR_DB_PROVIDER=pinecone.
# Where to get it:
# - Pinecone console: https://app.pinecone.io/
# - API key docs: https://docs.pinecone.io/guides/get-started/quickstart
PINECONE_API_KEY=

# PINECONE_INDEX
# What it is used for: Name of Pinecone index storing chunk vectors.
# Where to get it:
# - Create index in Pinecone console: https://app.pinecone.io/
# - Index docs: https://docs.pinecone.io/guides/indexes/create-an-index
PINECONE_INDEX=

# PINECONE_NAMESPACE
# What it is used for: Logical partition inside Pinecone index.
# Where to get it: Set manually (for example college-knowledge).
PINECONE_NAMESPACE=college-knowledge

# RAG_TOP_K
# What it is used for: Number of top retrieved chunks used as context.
# Where to get it: Set manually. Typical range is 3 to 8.
RAG_TOP_K=6

# RAG_CONFIDENCE_THRESHOLD
# What it is used for: Confidence cutoff below which escalation is suggested.
# Where to get it: Set manually after testing quality. Range is 0.0 to 1.0.
RAG_CONFIDENCE_THRESHOLD=0.6

# RAG_OUT_OF_SCOPE_THRESHOLD
# What it is used for: If average retrieval confidence drops below this, the chat is auto-escalated to a live agent.
# Where to get it: Set manually after QA. Typical range is 0.35 to 0.5.
RAG_OUT_OF_SCOPE_THRESHOLD=0.45

# DATA_DIR
# What it is used for: Path to dataset folder used by ingestion.
# Where to get it: Set manually to your mounted data directory.
DATA_DIR=../data

# =========================
# Client Runtime (Vercel)
# =========================

# VITE_MS_CLIENT_ID
# What it is used for: Microsoft Entra app client ID for agent popup sign-in.
VITE_MS_CLIENT_ID=

# VITE_MS_TENANT_ID
# What it is used for: Tenant id or 'common' for multi-tenant sign-in.
VITE_MS_TENANT_ID=common

# VITE_MS_REDIRECT_URI
# What it is used for: Redirect URI registered in Entra app (usually your /agent page URL).
VITE_MS_REDIRECT_URI=

# VITE_CHATBOT_LOGO_URL
# What it is used for: Overrides default chatbot logo (/Sona_College_of_Technology_logo.jpg) with a hosted image URL.
VITE_CHATBOT_LOGO_URL=
